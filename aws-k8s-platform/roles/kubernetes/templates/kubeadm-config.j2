apiVersion: kubeadm.k8s.io/v1beta3
kind: ClusterConfiguration

kubernetesVersion: stable

clusterName: "k8s-lab"

controlPlaneEndpoint: "{{ haproxy_vip }}:6443"

networking:
  podSubnet: "{{ pod_cidr }}"
  serviceSubnet: "{{ service_cidr }}"

apiServer:
  extraArgs:
    authorization-mode: "Node,RBAC"

controllerManager: {}

scheduler: {}
