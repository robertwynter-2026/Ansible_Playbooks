k8s-controller-1 ansible_host=10.0.0.11
k8s-controller-2 ansible_host=10.0.0.12

[k8s_workers]
k8s-worker-0 ansible_host=10.0.0.20
k8s-worker-1 ansible_host=10.0.0.21
k8s-worker-2 ansible_host=10.0.0.22
k8s-worker-3 ansible_host=10.0.0.23
k8s-worker-4 ansible_host=10.0.0.24
k8s-worker-5 ansible_host=10.0.0.25
k8s-worker-6 ansible_host=10.0.0.26

# --- High Availability & Networking ---
[haproxy]
haproxy-0 ansible_host=10.0.0.30
haproxy-1 ansible_host=10.0.0.31

# --- Identity & Access Management ---
[idm]
idm-0 ansible_host=10.0.0.40
idm-1 ansible_host=10.0.0.41
